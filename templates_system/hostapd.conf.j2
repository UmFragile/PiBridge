# hostapd configuration for AP "{{ ap.name }}" — generated by travelrouter.
interface={{ ifname }}
driver=nl80211
country_code={{ country }}
ieee80211d=1
ssid={{ ap.ssid }}
{% if ap.band == '5' %}
hw_mode=a
{% else %}
hw_mode=g
{% endif %}
channel={{ ap.channel }}
ignore_broadcast_ssid={{ 1 if ap.hidden else 0 }}
ap_isolate={{ 1 if ap.client_isolation else 0 }}
max_num_sta={{ ap.max_clients }}
{% if ap.band == '5' %}
ieee80211ac=1
wmm_enabled=1
{% else %}
ieee80211n=1
wmm_enabled=1
{% endif %}
{% if ap.psk %}
wpa=2
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP
wpa_passphrase={{ ap.psk }}
{% else %}
# OPEN network — no encryption.
{% endif %}
# MAC ACL: 0=accept-unless-deny, 1=deny-unless-accept. Lists in macacl files.
macaddr_acl=0
deny_mac_file={{ "/etc/travelrouter/generated/hostapd/ap%s.deny" % (ap.id or 0) }}
accept_mac_file={{ "/etc/travelrouter/generated/hostapd/ap%s.accept" % (ap.id or 0) }}
