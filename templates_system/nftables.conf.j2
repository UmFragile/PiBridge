#!/usr/sbin/nft -f
# nftables ruleset — generated by travelrouter. Do not edit by hand.
flush ruleset

table inet trouter {
    # Per-AP subnets used for inter-AP isolation.
    set ap_subnets {
        type ipv4_addr
        flags interval
{% if rules %}
        elements = { {% for r in rules %}{{ r.subnet }}{% if not loop.last %}, {% endif %}{% endfor %} }
{% endif %}
    }

    chain input {
        type filter hook input priority 0; policy drop;
        ct state established,related accept
        iif "lo" accept
        # Management UI + DHCP + DNS reachable from AP subnets only.
        ip saddr @ap_subnets tcp dport { 80, 443 } accept
        ip saddr @ap_subnets udp dport { 53, 67 } accept
        ip saddr @ap_subnets tcp dport 53 accept
        icmp type echo-request accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related accept
{% for r in rules %}
        # AP "{{ r.ap.name }}" ({{ r.ifname }}) policy={{ r.policy }}
{% if r.policy == 'isolated' %}
        iifname "{{ r.ifname }}" drop
{% else %}
        # Mark this AP's egress so policy routing picks the right table.
        iifname "{{ r.ifname }}" meta mark set {{ r.mark }}
{% if r.isolation %}
        # Client isolation: block intra-subnet forwarding.
        iifname "{{ r.ifname }}" oifname "{{ r.ifname }}" drop
{% endif %}
        iifname "{{ r.ifname }}" accept
{% endif %}
{% endfor %}
        # Block any forwarding between distinct AP subnets (no cross-AP leak).
        ip saddr @ap_subnets ip daddr @ap_subnets drop
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        # Masquerade everything heading to a non-AP egress (WAN or tunnel).
        ip saddr @ap_subnets oifname != { {% for r in rules %}"{{ r.ifname }}"{% if not loop.last %}, {% endif %}{% endfor %} } masquerade
    }
}
