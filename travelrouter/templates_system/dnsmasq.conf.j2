# dnsmasq configuration — generated by travelrouter.
# DHCP + DNS, scoped per access point interface.
bind-interfaces
domain-needed
bogus-priv
no-resolv
{% for scope in scopes %}

# ---- AP "{{ scope.ap.name }}" on {{ scope.ifname }} ----
interface={{ scope.ifname }}
dhcp-range={{ scope.ifname }},{{ scope.start }},{{ scope.end }},255.255.255.0,12h
dhcp-option={{ scope.ifname }},3,{{ scope.gateway }}
dhcp-option={{ scope.ifname }},6,{{ scope.dns | join(',') }}
{% for dns in scope.dns %}
server={{ dns }}
{% endfor %}
{% endfor %}
{% for r in reservations %}
dhcp-host={{ r.mac }},{{ r.reserved_ip }}{% if r.label %},{{ r.label }}{% endif %}

{% endfor %}
